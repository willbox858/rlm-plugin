{
  "agent": "gather-context-worker",
  "output_format": "json",
  "json_schema": {
    "type": "object",
    "properties": { "result": { "type": "string" } },
    "required": ["result"]
  },
  "stdin": "devnull",
  "env_defaults": {
    "GC_MAX_AGENTS": "50",
    "GC_MAX_FILE_SIZE": "512000",
    "GC_EXCLUDE": "node_modules,.git,target,dist,build,out,__pycache__,.venv,vendor,.claude,*.lock"
  }
}
