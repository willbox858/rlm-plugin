{
  "agent": "rlm-child",
  "output_format": "json",
  "json_schema": {
    "type": "object",
    "properties": { "result": { "type": "string" } },
    "required": ["result"]
  },
  "stdin": "passthrough",
  "env_defaults": {
    "RLM_MAX_DEPTH": "2",
    "RLM_CHUNK_LINES": "2000",
    "RLM_CHUNK_BYTES": "80000",
    "RLM_OVERLAP_BYTES": "2000",
    "RLM_MAX_PARALLELISM": "0"
  }
}
